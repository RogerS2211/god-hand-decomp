# ── Game data — NEVER commit. Supply your own dumped disc. ───────────────────
*.iso
*.IRX
*.IMG
*.AFS
*.FST
/SLUS_*
GODHAND.*
# Extracted boot ELF + overlay tables are local-only. The dir stays traversable
# so the one committed leaf (rel/manifest.json) remains visible to git.
disc_extract/*
!disc_extract/rel/
disc_extract/rel/*
!disc_extract/rel/manifest.json

# ── Vendored toolchain & deps (restored by scripts/setup_toolchain.sh) ───────
compiler/
tools/m2c/
tools/asm-differ/
tools/decomp-permuter/
tools/wibo
tools/objdiff-cli
.venv/

# ── Build artifacts ──────────────────────────────────────────────────────────
build/
build-nm/
asm/
bin/

# Generated NON_MATCHING scoring build (regenerated by scripts/score_nm.sh)
config/nm/
expected/
*.o
*.elf
*.map
*.lst

# Splat auto-generated linker scripts / symbol lists (regenerate locally)
config/SLUS_215.03.ld
config/SLUS_215.03.d
config/*.gen.ld
config/*.gen.d
config/undefined_funcs_auto.txt
config/undefined_syms_auto.txt

# objdiff project is generated by `python compile.py --setup`. A copy is
# committed for convenience; uncomment to keep it out of diffs while iterating.
# objdiff.json

