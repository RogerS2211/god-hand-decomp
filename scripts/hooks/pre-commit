#!/usr/bin/env bash
# pre-commit hook for godhand-recomp — the commit-time ratchet.
#
# Installed automatically by scripts/setup_toolchain.sh, which points
# core.hooksPath at scripts/hooks/ so this version-tracked file runs on
# every commit (no .git symlink to drift). Before 2026-06-05 the hook was
# opt-in and usually left uninstalled, so the ratchet was honor-system — a
# workflow-audit gap.
#
# Escape hatches:
#   GODHAND_NO_HOOK=1           skip the hook (env: this commit or your shell)
#   GODHAND_PRECOMMIT_CHECKS=…  run a fast subset, e.g. "build,score,state"
#                               (default: the full session_check.sh suite)
#   git commit --no-verify      bypass once (only for a ratchet-loosening
#                               task with a DECISIONS.md entry)
set -euo pipefail

if [[ -n "${GODHAND_NO_HOOK:-}" ]]; then
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
HARNESS="$ROOT/scripts/session_check.sh"

if [[ ! -x "$HARNESS" ]]; then
    echo "pre-commit: $HARNESS missing or not executable; skipping." >&2
    exit 0
fi

# Optional fast subset; empty/unset runs the full default suite.
CHECKS="${GODHAND_PRECOMMIT_CHECKS:-}"
if [[ -n "$CHECKS" ]]; then
    HARNESS_ARGS=("$CHECKS")
else
    HARNESS_ARGS=()
fi

if ! "$HARNESS" "${HARNESS_ARGS[@]}"; then
    cat >&2 <<'EOF'

pre-commit: session_check.sh failed.

Refusing the commit because the ratchet has regressed.  See output
above for which sub-check failed.  Fix, re-run scripts/session_check.sh
to confirm green, then commit again.

To bypass (only for an explicit ratchet-loosening task that has a
DECISIONS.md entry):  git commit --no-verify
EOF
    exit 1
fi
